{
  "name": "query-vault",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "auth:schema": "auth generate --output .output/auth-schema.ts --yes"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@better-auth/redis-storage": "1.6.23",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/noto-serif": "^5.2.9",
    "@react-router/node": "7.15.1",
    "@react-router/serve": "7.15.1",
    "@t3-oss/env-core": "0.13.11",
    "@tabler/icons-react": "^3.44.0",
    "auth": "^1.6.23",
    "better-auth": "1.6.23",
    "class-variance-authority": "^0.7.1",
    "clipboardy": "5.3.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "ioredis": "5.11.1",
    "isbot": "^5",
    "postgres": "3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.15.1",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "valibot": "1.4.2"
  },
  "devDependencies": {
    "@react-router/dev": "7.15.1",
    "@tailwindcss/vite": "^4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "0.31.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vite": "^8"
  }
}
